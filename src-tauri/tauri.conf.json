{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TinyLocal",
  "version": "1.0.0",
  "identifier": "com.tinylocal.app",
  "build": {
    "beforeDevCommand": "npm run vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TinyLocal",
        "width": 800,
        "height": 920,
        "minWidth": 640,
        "minHeight": 720,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "shortDescription": "TinyPNG 本地图片压缩工具",
    "longDescription": "基于 TinyPNG API 的本地桌面图片压缩工具，支持多 Key 自动切换与批量打包下载。"
  },
  "plugins": {}
}
